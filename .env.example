# Copy to airflow/.env and fill values

# Airflow encryption key — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Neon Postgres connection string (from Neon dashboard → Connection Details → psql)
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
POSTGRES_URL=

# Cloudflare R2 (S3-compatible object storage)
# Get from: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RAW=market-pulse-raw

# Optional — FRED macro extractor (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Optional — Slack webhook for alerts
SLACK_WEBHOOK_URL=
